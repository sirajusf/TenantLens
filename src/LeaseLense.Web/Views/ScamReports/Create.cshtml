@model LeaseLense.Web.Models.ScamReports.ScamReportCreatePageViewModel
@{
    ViewData["Title"] = "Submit Scam Report";
}

<section class="mvp-shell reveal">
    <div class="mvp-hero">
        <h1>Submit Scam/Fraud Report</h1>
        <p>Help the renter community by reporting suspicious listings or payment behavior.</p>
        <p class="mvp-text">You can submit for any property. Verified Stay appears only when the report matches your verified residency.</p>
    </div>
    @if (!Model.CanSubmit && !string.IsNullOrWhiteSpace(Model.RestrictionMessage))
    {
        <div class="mvp-error">@Model.RestrictionMessage</div>
    }

    <form asp-action="Create" method="post" class="mvp-form">
        <div asp-validation-summary="ModelOnly" class="mvp-error"></div>
        <div class="mvp-form-grid">
            <div class="mvp-field property-select-field">
                <label asp-for="Form.PropertyId" class="mvp-label">Property</label>
                <select asp-for="Form.PropertyId" class="mvp-select">
                    <option value="">Select property</option>
                    @foreach (var property in Model.Properties)
                    {
                        <option value="@property.Id">@property.Label</option>
                    }
                </select>
                <span asp-validation-for="Form.PropertyId" class="mvp-error"></span>
            </div>

            <div class="mvp-field full">
                <label class="mvp-label">
                    <input asp-for="Form.PropertyNotListed" type="checkbox" />
                    Property not listed (add it now)
                </label>
            </div>

            <div class="mvp-field property-not-listed-field">
                <label asp-for="Form.NewCommunityName" class="mvp-label">Community name</label>
                <input asp-for="Form.NewCommunityName" class="mvp-input" />
                <span asp-validation-for="Form.NewCommunityName" class="mvp-error"></span>
            </div>

            <div class="mvp-field property-not-listed-field">
                <label asp-for="Form.NewPropertyTitle" class="mvp-label">New property title</label>
                <input asp-for="Form.NewPropertyTitle" class="mvp-input" />
                <span asp-validation-for="Form.NewPropertyTitle" class="mvp-error"></span>
            </div>

            <div class="mvp-field property-not-listed-field">
                <label asp-for="Form.NewPropertyStreetAddress" class="mvp-label">Street address</label>
                <input asp-for="Form.NewPropertyStreetAddress" class="mvp-input" />
                <span asp-validation-for="Form.NewPropertyStreetAddress" class="mvp-error"></span>
            </div>

            <div class="mvp-field property-not-listed-field">
                <label asp-for="Form.NewPropertyCity" class="mvp-label">City</label>
                <input asp-for="Form.NewPropertyCity" class="mvp-input" />
                <span asp-validation-for="Form.NewPropertyCity" class="mvp-error"></span>
            </div>

            <div class="mvp-field property-not-listed-field">
                <label asp-for="Form.NewPropertyCountry" class="mvp-label">Country</label>
                <input asp-for="Form.NewPropertyCountry" class="mvp-input" />
                <span asp-validation-for="Form.NewPropertyCountry" class="mvp-error"></span>
            </div>


            <div class="mvp-field">
                <label asp-for="Form.ScamType" class="mvp-label">Scam type</label>
                <input asp-for="Form.ScamType" class="mvp-input" />
                <span asp-validation-for="Form.ScamType" class="mvp-error"></span>
            </div>

            <div class="mvp-field">
                <label asp-for="Form.SeverityScore" class="mvp-label">Severity score (1-5)</label>
                <input asp-for="Form.SeverityScore" type="number" min="1" max="5" step="0.1" class="mvp-input" />
                <span asp-validation-for="Form.SeverityScore" class="mvp-error"></span>
            </div>

            <div class="mvp-field full">
                <label asp-for="Form.Description" class="mvp-label">Description</label>
                <textarea asp-for="Form.Description" class="mvp-textarea" rows="4"></textarea>
                <span asp-validation-for="Form.Description" class="mvp-error"></span>
            </div>
        </div>
        <div class="mvp-actions">
            <button type="submit" class="mvp-btn danger" disabled="@(!Model.CanSubmit)">Submit Report</button>
            <a class="mvp-btn ghost" asp-action="Index">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const checkbox = document.getElementById('Form_PropertyNotListed');
            const fields = document.querySelectorAll('.property-not-listed-field');
            const propertySelectField = document.querySelector('.property-select-field');
            const propertySelect = document.getElementById('Form_PropertyId');
            if (!checkbox || fields.length === 0 || !propertySelectField || !propertySelect) return;

            const toggle = () => {
                fields.forEach((field) => field.classList.toggle('is-hidden', !checkbox.checked));
                propertySelect.disabled = checkbox.checked;
                propertySelectField.classList.toggle('is-deactivated', checkbox.checked);
                if (checkbox.checked) {
                    propertySelect.value = '';
                }
            };

            checkbox.addEventListener('change', toggle);
            toggle();
        })();
    </script>
}
