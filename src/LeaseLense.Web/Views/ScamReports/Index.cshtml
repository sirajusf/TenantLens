@model LeaseLense.Web.Models.ScamReports.ScamReportIndexViewModel
@{
    ViewData["Title"] = "Scam Reports";
    var hasActiveFilters =
        !string.IsNullOrWhiteSpace(Model.QueryText)
        || !string.IsNullOrWhiteSpace(Model.City)
        || Model.MinSeverity.HasValue;
}

<section class="mvp-shell reveal">

    <div class="page-hero">
        <div class="page-hero__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/>
                <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
        </div>
        <div class="page-hero__text">
            <h1>Scam &amp; Fraud Reports</h1>
            <p>Community-reported fraud signals to help renters avoid high-risk listings before they commit.</p>
        </div>
        <a class="mvp-btn page-hero__cta" asp-action="Create">Submit Report</a>
    </div>

    @if (TempData["ScamReportSuccess"] is string successMessage)
    {
        <div class="mvp-notice mvp-notice--success" role="status">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="18" height="18" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span>@successMessage</span>
        </div>
    }

    <form method="get" class="mvp-hero reviews-filter-panel" role="search" aria-labelledby="scam-filter-heading">
        <h2 class="reviews-filter-panel__title" id="scam-filter-heading">Filter reports</h2>
        <fieldset class="reviews-filters">
            <legend class="visually-hidden">Filter and sort scam reports</legend>
            <div class="reviews-filters__grid">
                <div class="mvp-field reviews-filters__field reviews-filters__field--wide">
                    <label class="reviews-filters__label" for="scam-filter-q">Search</label>
                    <input class="mvp-input" id="scam-filter-q" name="q" value="@Model.QueryText"
                           placeholder="Property, address, scam type, or description" autocomplete="off" />
                </div>
                <div class="mvp-field reviews-filters__field">
                    <label class="reviews-filters__label" for="scam-filter-city">City</label>
                    <input class="mvp-input" id="scam-filter-city" name="city" value="@Model.City"
                           placeholder="e.g. Tampa" autocomplete="off" />
                </div>
                <div class="mvp-field reviews-filters__field">
                    <label class="reviews-filters__label" for="scam-filter-min-severity">Min severity (0–5)</label>
                    <input class="mvp-input" id="scam-filter-min-severity" name="minSeverity" type="number"
                           step="0.5" min="0" max="5"
                           value="@(Model.MinSeverity?.ToString() ?? "")" placeholder="e.g. 3" />
                </div>
                <div class="mvp-field reviews-filters__field">
                    <label class="reviews-filters__label" for="scam-filter-sort">Sort by</label>
                    <select class="mvp-select" id="scam-filter-sort" name="sortBy">
                        <option value="newest" selected="@(Model.SortBy == "newest" || string.IsNullOrEmpty(Model.SortBy) ? "selected" : null)">Newest first</option>
                        <option value="severity" selected="@(Model.SortBy == "severity" ? "selected" : null)">Highest severity</option>
                    </select>
                </div>
            </div>
            <div class="reviews-filters__actions">
                @if (hasActiveFilters)
                {
                    <a class="reviews-filters__clear" asp-controller="ScamReports" asp-action="Index">Clear filters</a>
                }
                <button class="mvp-btn reviews-filters__submit" type="submit">Apply filters</button>
            </div>
        </fieldset>
    </form>

    @if (Model.LlmUnavailable)
    {
        <div class="mvp-notice mvp-notice--warn" role="alert">
            <span>AI parsing is temporarily unavailable — showing keyword results instead.</span>
        </div>
    }
    @if (Model.NlFallback)
    {
        <div class="mvp-notice mvp-notice--info" role="status">
            <span>No direct matches — AI found related scam report results from your query.</span>
        </div>
    }
    @if (Model.InterpretedFilters.Any())
    {
        <div class="mvp-tags" aria-label="Interpreted search filters">
            @foreach (var filter in Model.InterpretedFilters)
            {
                <span class="mvp-badge">@filter</span>
            }
        </div>
    }

    @if (!Model.Reports.Any())
    {
        <div class="reviews-state reviews-state--empty">
            <h2 class="reviews-state__title">No reports found</h2>
            <p class="reviews-state__text">
                @if (hasActiveFilters)
                {
                    @:No scam reports match these filters. Try widening your search or clearing filters.
                }
                else
                {
                    @:No scam reports have been submitted yet. Help protect the community by reporting suspicious activity.
                }
            </p>
            <div class="reviews-state__actions">
                <a class="mvp-btn" asp-action="Create">Submit a report</a>
                @if (hasActiveFilters)
                {
                    <a class="mvp-btn ghost" asp-controller="ScamReports" asp-action="Index">Clear filters</a>
                }
            </div>
        </div>
    }
    else
    {
        <div class="scam-results-header">
            <p class="scam-results-count">@Model.Reports.Count report@(Model.Reports.Count == 1 ? "" : "s") found</p>
        </div>
        <div class="mvp-grid">
            @foreach (var report in Model.Reports)
            {
                var severityScore = report.SeverityScore ?? 0;
                var severityClass = severityScore >= 4 ? "danger" : severityScore >= 2.5m ? "warn" : "primary";
                var cardAccent = severityScore >= 4 ? "accent-coral" : "accent-indigo";
                <article class="mvp-card @cardAccent scam-report-card">
                    <div class="mvp-card-head">
                        <h2 class="scam-report-card__title">@report.PropertyTitle</h2>
                        <span class="mvp-badge @severityClass scam-severity-badge" title="Severity score out of 5">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="11" height="11" aria-hidden="true">
                                <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
                            </svg>
                            Severity @severityScore.ToString("0.0")
                        </span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(report.CommunityName))
                    {
                        <p class="mvp-subtext scam-report-card__community">@report.CommunityName</p>
                    }
                    <div class="scam-report-card__meta">
                        <span class="scam-meta-chip scam-meta-chip--type">@report.ScamType</span>
                        <span class="scam-meta-chip scam-meta-chip--city">@report.City</span>
                    </div>
                    <p class="mvp-text scam-report-card__desc">@report.Description</p>
                    <div class="mvp-tags scam-report-card__footer">
                        <span class="mvp-badge">Reported @report.DateReported.ToLocalTime().ToString("MMM d, yyyy")</span>
                        @if (!string.IsNullOrWhiteSpace(report.VerificationBadge))
                        {
                            <span class="mvp-badge success">@report.VerificationBadge</span>
                        }
                        <a class="card-action-link scam-report-card__link"
                           asp-controller="Properties"
                           asp-action="Details"
                           asp-route-id="@report.PropertyId">View property →</a>
                    </div>
                </article>
            }
        </div>
    }

</section>
<button type="button" class="list-top-btn" data-scroll-top aria-label="Back to top">Top</button>
