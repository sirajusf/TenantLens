<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LeaseLense</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Sora:wght@500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/styles/styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/styles/index.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/styles/mvp.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LeaseLense.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <div id="page-loader" class="page-loader-overlay" role="status" aria-live="polite" aria-label="Loading page">
        <div class="page-loader-content">
            <div class="page-loader-brand">
                <span class="brand-dot"></span>
                LeaseLense
            </div>
            <div class="page-loader-spinner" aria-hidden="true"></div>
            <p>Preparing your renter intelligence experience...</p>
        </div>
    </div>
    <header class="site-header">
        <div class="container nav-wrapper">
            <a class="brand" asp-area="" asp-controller="Home" asp-action="Index">
                <span class="brand-dot"></span>
                LeaseLense
            </a>
            <div class="nav-actions">
                <nav class="main-nav" aria-label="Main navigation">
                    <a asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                    <a asp-area="" asp-controller="Properties" asp-action="Index">Properties</a>
                    <a asp-area="" asp-controller="Reviews" asp-action="Index">Reviews</a>
                    <a asp-area="" asp-controller="ScamReports" asp-action="Index">Scam Reports</a>
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="mvp-btn ghost">Sign Out</button>
                        </form>
                    }
                    else
                    {
                        <a asp-area="" asp-controller="Account" asp-action="Login">Sign In</a>
                        <a asp-area="" asp-controller="Account" asp-action="Register">Sign Up</a>
                    }
                </nav>
                <label class="theme-toggle" for="theme-switch" aria-label="Toggle dark mode">
                    <span class="theme-label">Dark</span>
                    <span class="theme-switch-ui">
                        <input id="theme-switch" class="theme-switch-input" type="checkbox" />
                        <span class="theme-switch-slider" aria-hidden="true"></span>
                    </span>
                </label>
            </div>
        </div>
    </header>
    <div class="site-main">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-shell">
        <div class="container">
            &copy; 2026 LeaseLense - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/script.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
