@model LeaseLense.Web.Models.Search.NlSearchViewModel
@using LeaseLense.Application.Search
@{
    ViewData["Title"] = string.IsNullOrWhiteSpace(Model.Query) ? "Search" : $"Search: {Model.Query}";
}

<section class="mvp-shell reveal">
    <div class="page-hero">
        <div class="page-hero__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8" />
                <line x1="21" y1="21" x2="16.65" y2="16.65" />
            </svg>
        </div>
        <div class="page-hero__text">
            <h1>Search</h1>
            <p>Search properties, reviews, and scam reports in one place.</p>
        </div>
    </div>

    <form method="get" asp-controller="Search" asp-action="Index" class="mvp-hero reviews-filter-panel" role="search" aria-labelledby="global-search-heading">
        <h2 class="reviews-filter-panel__title" id="global-search-heading">Find anything</h2>
        <fieldset class="reviews-filters">
            <legend class="visually-hidden">Global search query</legend>
            <div class="reviews-filters__grid">
                <div class="mvp-field reviews-filters__field reviews-filters__field--wide">
                    <label class="reviews-filters__label" for="global-search-input">Search query</label>
                    <input id="global-search-input" class="mvp-input" type="search" name="q"
                           value="@Model.Query"
                           placeholder="Try: apartments in Tampa under $1500 with good ratings"
                           autocomplete="off" autofocus />
                </div>
            </div>
            <div class="reviews-filters__actions">
                <a class="reviews-filters__clear" asp-controller="Search" asp-action="Index">Clear search</a>
                <button class="mvp-btn reviews-filters__submit" type="submit">Search</button>
            </div>
        </fieldset>
    </form>

    @if (Model.HasSearched)
    {
        @if (Model.LlmUnavailable)
        {
            <div class="mvp-notice mvp-notice--warn" role="alert">
                <span>AI parsing is temporarily unavailable — showing keyword results instead.</span>
            </div>
        }
        @if (Model.NlFallback)
        {
            <div class="mvp-notice mvp-notice--info" role="status">
                <span>No direct matches — AI found related results from your query.</span>
            </div>
        }
        @if (Model.InterpretedFilters.Any())
        {
            <div class="mvp-tags" aria-label="Interpreted search filters">
                @foreach (var filter in Model.InterpretedFilters)
                {
                    <span class="mvp-badge">@filter</span>
                }
                @foreach (var target in Model.TargetEntityTypes)
                {
                    var label = target switch
                    {
                        SearchEntityType.Review => "Reviews",
                        SearchEntityType.ScamReport => "Scam Reports",
                        _ => "Properties"
                    };
                    <span class="mvp-badge primary">@label</span>
                }
            </div>
        }
        <div class="prop-results-header">
            <p class="scam-results-count">
                @if (Model.TotalResults == 0)
                {
                    @:No results found
                }
                else
                {
                    @:@Model.TotalResults result@(Model.TotalResults == 1 ? "" : "s") found
                }
                @if (!string.IsNullOrWhiteSpace(Model.Query))
                {
                    @: for &ldquo;@Model.Query&rdquo;
                }
            </p>
        </div>

            <!-- ── Property results ── -->
            @if (Model.PropertyResults.Any())
            {
                <div class="mvp-grid property-directory-grid">
                    @foreach (var match in Model.PropertyResults)
                    {
                        var p = match.Property;
                        <a class="mvp-card accent-cyan property-directory-card"
                           asp-controller="Properties"
                           asp-action="Details"
                           asp-route-id="@p.PropertyId"
                           aria-label="Open @p.Title property page">
                            <div class="mvp-card-head">
                                <h2 class="property-title">@p.Title</h2>
                                @if (!string.IsNullOrWhiteSpace(p.PropertyType))
                                {
                                    <span class="mvp-badge">@p.PropertyType</span>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(match.CommunityName))
                            {
                                <p class="mvp-subtext property-community">@match.CommunityName</p>
                            }
                            <p class="mvp-subtext property-address">@p.StreetAddress</p>
                            <p class="mvp-text property-location">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="12" height="12" aria-hidden="true" style="flex-shrink:0">
                                    <path fill-rule="evenodd" d="M11.536 3.464a5 5 0 0 1 0 7.072L8 14.07l-3.536-3.534a5 5 0 1 1 7.072-7.072v.001zm1.06 8.132a6.5 6.5 0 1 0-9.192 0l3.535 3.536a1.5 1.5 0 0 0 2.12 0l3.537-3.536zM8 9a2 2 0 1 1 0-4 2 2 0 0 1 0 4z" clip-rule="evenodd"/>
                                </svg>
                                @p.City, @p.Country
                            </p>
                            <div class="mvp-tags">
                                @if (!string.IsNullOrWhiteSpace(p.LandlordName))
                                {
                                    <span class="mvp-badge">@p.LandlordName</span>
                                }
                                <span class="mvp-badge prop-open-badge">View →</span>
                            </div>
                        </a>
                    }
                </div>
            }

            <!-- ── Review results ── -->
            @if (Model.ReviewResults.Any())
            {
                <div class="mvp-grid">
                    @foreach (var match in Model.ReviewResults)
                    {
                        var rv = match.Review;
                        var isVerified = string.Equals(rv.VerificationStatus, "verified_stay", StringComparison.OrdinalIgnoreCase);
                        <article class="mvp-card accent-indigo">
                            <div class="mvp-card-head">
                                <h2>@(match.Property?.Title ?? "Unknown property")</h2>
                                @if (isVerified)
                                {
                                    <span class="mvp-badge success">✓ Verified</span>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(match.CommunityName))
                            {
                                <p class="mvp-subtext">@match.CommunityName</p>
                            }
                            @if (match.Property is not null)
                            {
                                <p class="mvp-subtext">@match.Property.StreetAddress, @match.Property.City</p>
                            }
                            @if (!string.IsNullOrWhiteSpace(rv.ReviewText))
                            {
                                <p class="mvp-text">@rv.ReviewText</p>
                            }
                            <div class="mvp-tags">
                                @if (rv.MonthlyRent.HasValue)
                                {
                                    <span class="mvp-badge">Rent @rv.MonthlyRent.Value.ToString("C0")/mo</span>
                                }
                                @if (rv.MoveInYear.HasValue)
                                {
                                    <span class="mvp-badge">Moved in @rv.MoveInYear</span>
                                }
                                <a class="card-action-link" asp-controller="Properties" asp-action="Details" asp-route-id="@rv.PropertyId">View property →</a>
                            </div>
                        </article>
                    }
                </div>
            }

            <!-- ── Scam report results ── -->
            @if (Model.ScamReportResults.Any())
            {
                <div class="mvp-grid">
                    @foreach (var match in Model.ScamReportResults)
                    {
                        var sr = match.ScamReport;
                        var sev = sr.SeverityScore ?? 0;
                        var sevClass = sev >= 4 ? "danger" : sev >= 2.5m ? "warn" : "primary";
                        var cardAccent = sev >= 4 ? "accent-coral" : "accent-indigo";
                        <article class="mvp-card @cardAccent scam-report-card">
                            <div class="mvp-card-head">
                                <h2 class="scam-report-card__title">@(match.Property?.Title ?? "Unknown property")</h2>
                                <span class="mvp-badge @sevClass scam-severity-badge">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="11" height="11" aria-hidden="true">
                                        <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
                                    </svg>
                                    Severity @sev.ToString("0.0")
                                </span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(match.CommunityName))
                            {
                                <p class="mvp-subtext">@match.CommunityName</p>
                            }
                            <div class="scam-report-card__meta">
                                <span class="scam-meta-chip scam-meta-chip--type">@sr.ScamType</span>
                                @if (match.Property is not null)
                                {
                                    <span class="scam-meta-chip scam-meta-chip--city">@match.Property.City</span>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(sr.Description))
                            {
                                <p class="mvp-text scam-report-card__desc">@sr.Description</p>
                            }
                            <div class="mvp-tags scam-report-card__footer">
                                <span class="mvp-badge">@sr.DateReported.ToLocalTime().ToString("MMM d, yyyy")</span>
                                <a class="card-action-link scam-report-card__link" asp-controller="Properties" asp-action="Details" asp-route-id="@sr.PropertyId">View property →</a>
                            </div>
                        </article>
                    }
                </div>
            }

            <!-- ── Empty state ── -->
            @if (Model.TotalResults == 0)
            {
                <div class="reviews-state reviews-state--empty">
                    <h2 class="reviews-state__title">No results found</h2>
                    <p class="reviews-state__text">Try a different city, landlord name, or rephrase your query.</p>
                    <div class="reviews-state__actions">
                        <a class="mvp-btn" asp-controller="Search" asp-action="Index">Clear search</a>
                    </div>
                </div>
            }
    }
    else
    {
        <div class="reviews-state reviews-state--empty">
            <h2 class="reviews-state__title">Start searching</h2>
            <p class="reviews-state__text">Search by city, address, landlord name, rent range, or scam type.</p>
            <div class="reviews-state__actions">
                <a class="mvp-btn ghost" asp-controller="Properties" asp-action="Index">Browse Properties</a>
                <a class="mvp-btn ghost" asp-controller="Reviews" asp-action="Index">Browse Reviews</a>
                <a class="mvp-btn ghost" asp-controller="ScamReports" asp-action="Index">Browse Scam Reports</a>
            </div>
        </div>
    }
</section>
