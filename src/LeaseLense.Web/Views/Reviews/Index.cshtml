@model LeaseLense.Web.Models.Reviews.ReviewListViewModel
@{
    ViewData["Title"] = "Reviews";
    var toastMessage = TempData["ReviewSubmitSuccess"] as string;
    var hasActiveFilters =
        !string.IsNullOrWhiteSpace(Model.PropertyQuery)
        || !string.IsNullOrWhiteSpace(Model.City)
        || Model.MinRent.HasValue
        || Model.MaxRent.HasValue
        || Model.MinRating.HasValue;
}

<section id="reviews-page-root"
         class="mvp-shell reveal"
         data-reviews-toast="@toastMessage"
         aria-label="Reviews">
    <div class="mvp-hero reviews-page-hero">
        <div class="reviews-page-head">
            <div class="reviews-page-head__intro">
                <h1>Reviews</h1>
                <p class="reviews-page-head__tagline">Privacy-safe identities and verifiable quality signals.</p>
            </div>
            <div class="reviews-page-head__actions">
                <a class="mvp-btn reviews-cta--primary" asp-action="Create">Write a Review</a>
                <a class="mvp-btn ghost" asp-controller="Properties" asp-action="Index">Browse Properties</a>
            </div>
        </div>
    </div>

    <form method="get"
          class="reviews-filter-panel mvp-hero"
          id="reviews-filter-form"
          aria-labelledby="reviews-filters-heading">
        <h2 class="reviews-filter-panel__title" id="reviews-filters-heading">Find reviews</h2>
        <fieldset class="reviews-filters">
            <legend class="visually-hidden">Filter and sort reviews</legend>
            <div class="reviews-filters__grid">
                <div class="mvp-field reviews-filters__field reviews-filters__field--wide">
                    <label class="reviews-filters__label" for="filter-property-query">Community, property, or address</label>
                    <input class="mvp-input"
                           id="filter-property-query"
                           name="propertyQuery"
                           value="@Model.PropertyQuery"
                           placeholder="e.g. Lakeview, 123 Main St, or Tampa"
                           autocomplete="off" />
                </div>
                <div class="mvp-field reviews-filters__field">
                    <label class="reviews-filters__label" for="filter-city">City</label>
                    <input class="mvp-input"
                           id="filter-city"
                           name="city"
                           value="@Model.City"
                           placeholder="Exact city match"
                           autocomplete="off" />
                </div>
                <div class="mvp-field reviews-filters__field">
                    <label class="reviews-filters__label" for="filter-min-rent">Min rent</label>
                    <input class="mvp-input"
                           id="filter-min-rent"
                           name="minRent"
                           type="number"
                           step="1"
                           min="0"
                           value="@(Model.MinRent?.ToString() ?? "")"
                           placeholder="Per month" />
                </div>
                <div class="mvp-field reviews-filters__field">
                    <label class="reviews-filters__label" for="filter-max-rent">Max rent</label>
                    <input class="mvp-input"
                           id="filter-max-rent"
                           name="maxRent"
                           type="number"
                           step="1"
                           min="0"
                           value="@(Model.MaxRent?.ToString() ?? "")"
                           placeholder="Per month" />
                </div>
                <div class="mvp-field reviews-filters__field">
                    <label class="reviews-filters__label" for="filter-min-rating">Min rating</label>
                    <input class="mvp-input"
                           id="filter-min-rating"
                           name="minRating"
                           type="number"
                           step="0.1"
                           min="0"
                           max="5"
                           value="@(Model.MinRating?.ToString() ?? "")"
                           placeholder="0–5" />
                </div>
                <div class="mvp-field reviews-filters__field">
                    <label class="reviews-filters__label" for="filter-sort">Sort by</label>
                    <select class="mvp-select" id="filter-sort" name="sortBy">
                        @if (Model.SortBy == "newest")
                        {
                            <option value="newest" selected>Newest</option>
                        }
                        else
                        {
                            <option value="newest">Newest</option>
                        }
                        @if (Model.SortBy == "rating")
                        {
                            <option value="rating" selected>Highest rating</option>
                        }
                        else
                        {
                            <option value="rating">Highest rating</option>
                        }
                        @if (Model.SortBy == "rent")
                        {
                            <option value="rent" selected>Lowest rent</option>
                        }
                        else
                        {
                            <option value="rent">Lowest rent</option>
                        }
                    </select>
                </div>
            </div>
            <div class="reviews-filters__actions">
                <a class="reviews-filters__clear"
                   asp-controller="Reviews"
                   asp-action="Index">Clear filters</a>
                <button class="mvp-btn reviews-filters__submit" type="submit">Apply filters</button>
            </div>
        </fieldset>
    </form>

    @if (Model.LlmUnavailable)
    {
        <div class="mvp-notice mvp-notice--warn" role="alert">
            <span>AI parsing is temporarily unavailable — showing keyword results instead.</span>
        </div>
    }
    @if (Model.NlFallback)
    {
        <div class="mvp-notice mvp-notice--info" role="status">
            <span>No direct matches — AI found related review results from your query.</span>
        </div>
    }
    @if (Model.InterpretedFilters.Any())
    {
        <div class="mvp-tags" aria-label="Interpreted search filters">
            @foreach (var filter in Model.InterpretedFilters)
            {
                <span class="mvp-badge">@filter</span>
            }
        </div>
    }

    <section class="reviews-results-panel"
             id="reviews-results-panel"
             aria-live="polite"
             aria-busy="false">

        @if (Model.HasLoadError)
        {
            <div class="reviews-state reviews-state--error" role="alert">
                <h2 class="reviews-state__title">Something went wrong</h2>
                <p class="reviews-state__text">@Model.LoadErrorMessage</p>
                <div class="reviews-state__actions">
                    <a class="mvp-btn" asp-controller="Reviews" asp-action="Index">Try again</a>
                    <a class="mvp-btn ghost" asp-controller="Properties" asp-action="Index">Browse properties</a>
                </div>
            </div>
        }
        else if (!Model.Reviews.Any())
        {
            <div class="reviews-state reviews-state--empty">
                <h2 class="reviews-state__title">No reviews found</h2>
                <p class="reviews-state__text">
                    @if (hasActiveFilters)
                    {
                        @:No reviews match these filters. Try widening your search or clearing filters.
                    }
                    else
                    {
                        @:There are no reviews yet. Be the first to share your experience.
                    }
                </p>
                <div class="reviews-state__actions">
                    <a class="mvp-btn reviews-cta--primary" asp-action="Create">Write a review</a>
                    @if (hasActiveFilters)
                    {
                        <a class="mvp-btn ghost" asp-controller="Reviews" asp-action="Index">Clear filters</a>
                    }
                    <a class="mvp-btn ghost" asp-controller="Properties" asp-action="Index">Browse properties</a>
                </div>
            </div>
        }
        else
        {
            <div class="mvp-grid" id="reviews-scroll-grid">
                @{
                    var index = 0;
                }
                @foreach (var review in Model.Reviews)
                {
                    var textId = $"review-text-{index}";
                    <article class="mvp-card accent-indigo review-lazy-card reviews-card" data-review-index="@index">
                        <div class="reviews-card__inner">
                            <header class="reviews-card__header">
                                <h3 class="reviews-card__title">@review.PropertyTitle</h3>
                                <span class="mvp-badge primary reviews-card__rating" title="Average rating">@review.AverageRating.ToString("0.0")<span class="reviews-card__rating-suffix">/5</span></span>
                            </header>
                            @if (!string.IsNullOrWhiteSpace(review.CommunityName))
                            {
                                <p class="reviews-card__community mvp-subtext">@review.CommunityName</p>
                            }
                            <p class="reviews-card__address mvp-subtext">@review.StreetAddress, @review.City</p>
                            <div class="reviews-card__body">
                                <p class="reviews-card__text reviews-card__text--clampable"
                                   id="@textId"
                                   data-review-clamp>@(review.ReviewText)</p>
                                <button type="button"
                                        class="reviews-card__expand"
                                        hidden
                                        data-review-expand
                                        aria-expanded="false"
                                        aria-controls="@textId">
                                    Read more
                                </button>
                            </div>
                            <footer class="reviews-card__footer">
                                <div class="reviews-card__chips">
                                    <span class="reviews-chip reviews-chip--persona">@review.AnonymizedReviewer</span>
                                    <span class="reviews-chip reviews-chip--rent">
                                        @if (review.MonthlyRent.HasValue)
                                        {
                                            @:Rent @review.MonthlyRent.Value.ToString("C0")
                                        }
                                        else
                                        {
                                            @:Rent not listed
                                        }
                                    </span>
                                    @if (review.IsVerifiedStay)
                                    {
                                        <span class="reviews-trust-badge">
                                            <svg class="reviews-trust-badge__icon" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                                                <path fill="currentColor" d="M6.27 10.87 3.4 8l1.06-1.06 1.8 1.8 4.33-4.33L12.6 5.47l-5.2 5.2a.75.75 0 0 1-1.13-.06Z" />
                                            </svg>
                                            Verified stay
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="reviews-chip reviews-chip--muted">Not verified</span>
                                    }
                                </div>
                                <a class="reviews-card__cta"
                                   asp-controller="Properties"
                                   asp-action="Details"
                                   asp-route-id="@review.PropertyId">View property</a>
                            </footer>
                        </div>
                    </article>
                    index++;
                }
            </div>
        }
    </section>
@section Scripts {
    <script src="~/js/reviews-index.js" asp-append-version="true"></script>
}
</section>
<button type="button" class="list-top-btn" data-scroll-top aria-label="Back to top">Top</button>
