@{
    ViewData["Title"] = "Visualizations";
}

<section class="page-frame reveal">
    <div class="content-hero">
        <h1>Visualizations</h1>
        <p>
            Interactive analytics for tenant behavior, scam trends, and property sentiment will be surfaced here
            in a clean dashboard-ready experience.
        </p>
        <p><a asp-controller="Home" asp-action="Index" class="inline-link">Back to Home</a></p>
