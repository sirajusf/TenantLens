@{
    ViewData["Title"] = "About";
}

<!-- ═══════════════════════════════════════════════════════════════
     HERO
═══════════════════════════════════════════════════════════════ -->
<section class="ab-hero">
    <div class="ab-hero__orbs" aria-hidden="true">
        <span class="ab-orb ab-orb--a"></span>
        <span class="ab-orb ab-orb--b"></span>
        <span class="ab-orb ab-orb--c"></span>
    </div>
    <div class="container ab-hero__inner">
        <span class="ab-eyebrow">University of South Florida &mdash; Spring 2026 &mdash; ADA Project</span>
        <h1 class="ab-hero__title">Built by renters,<br>for renters.</h1>
        <p class="ab-hero__sub">
            TenantLens is a rental intelligence platform that gives renters the transparency
            they deserve — community reviews, fraud reports, AI lease analysis, and smart search,
            all in one place.
        </p>
        <div class="ab-stats">
            <div class="ab-stat">
                <span class="ab-stat__num">4</span>
                <span class="ab-stat__label">Contributors</span>
            </div>
            <div class="ab-stat">
                <span class="ab-stat__num">3</span>
                <span class="ab-stat__label">AI Features</span>
            </div>
            <div class="ab-stat">
                <span class="ab-stat__num">4</span>
                <span class="ab-stat__label">Architecture Layers</span>
            </div>
            <div class="ab-stat">
                <span class="ab-stat__num">Azure</span>
                <span class="ab-stat__label">Powered</span>
            </div>
        </div>
    </div>
</section>

<div class="container ab-body">

    <!-- ═══════════════════════════════════════════════════════════════
         MISSION
    ═══════════════════════════════════════════════════════════════ -->
    <div class="ab-mission reveal">
        <div class="ab-mission__accent" aria-hidden="true"></div>
        <div class="ab-mission__content">
            <p class="ab-mission__label">Our Mission</p>
            <p class="ab-mission__text">
                Renting should feel safe, not stressful. We built TenantLens to reduce rental fraud,
                expose hidden lease costs, and give renters AI-powered tools to make confident decisions
                before signing — combining real tenant data, community scam reports, and intelligent
                document analysis in a single platform.
            </p>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════════
         WHAT WE BUILT
    ═══════════════════════════════════════════════════════════════ -->
    <div class="ab-features reveal">
        <h2 class="ab-section-title">What we built</h2>
        <div class="ab-feature-grid">

            <div class="ab-feature-card">
                <div class="ab-feature-card__icon ab-feature-card__icon--cyan">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="22" height="22" aria-hidden="true">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                        <polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                </div>
                <h3 class="ab-feature-card__title">Property Intelligence</h3>
                <p class="ab-feature-card__desc">A community-driven directory of rental properties enriched with tenant reviews, scam reports, and a multi-dimensional reputation score.</p>
            </div>

            <div class="ab-feature-card">
                <div class="ab-feature-card__icon ab-feature-card__icon--indigo">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="22" height="22" aria-hidden="true">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                        <line x1="16" y1="13" x2="8" y2="13"/>
                        <line x1="16" y1="17" x2="8" y2="17"/>
                        <polyline points="10 9 9 9 8 9"/>
                    </svg>
                </div>
                <h3 class="ab-feature-card__title">AI Lease Summarizer</h3>
                <p class="ab-feature-card__desc">Upload any lease PDF or image and receive a structured AI breakdown — rent, fees, deposits, risk clauses, and plain-English explanations in seconds.</p>
            </div>

            <div class="ab-feature-card">
                <div class="ab-feature-card__icon ab-feature-card__icon--violet">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="22" height="22" aria-hidden="true">
                        <circle cx="11" cy="11" r="8"/>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                        <path d="M11 8a3 3 0 0 1 0 6"/>
                    </svg>
                </div>
                <h3 class="ab-feature-card__title">Smart Search</h3>
                <p class="ab-feature-card__desc">Natural language search powered by Azure AI Foundry. Type "cheap apartments in Tampa with verified reviews" and the AI extracts every filter automatically.</p>
            </div>

        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════════
         TEAM
    ═══════════════════════════════════════════════════════════════ -->
    <div class="ab-team reveal">
        <h2 class="ab-section-title">The team</h2>
        <p class="ab-section-sub">Four students who turned a semester assignment into a full-stack AI platform.</p>

        <div class="ab-team-grid">

            <article class="ab-member-card">
                <div class="ab-member-card__photo-wrap">
                    <img class="ab-member-card__photo" src="/Siraj2.jpeg" alt="Mahammad Siraj Cheruvu" loading="lazy" />
                    <div class="ab-member-card__photo-overlay" aria-hidden="true"></div>
                </div>
                <div class="ab-member-card__body">
                    <span class="ab-member-card__role ab-member-card__role--lead">Project Lead</span>
                    <h3 class="ab-member-card__name">Mahammad Siraj Cheruvu</h3>
                    <p class="ab-member-card__desc">Coordinated planning, product vision, and final integration. Led full-stack architecture and all AI feature development.</p>
                </div>
            </article>

            <article class="ab-member-card">
                <div class="ab-member-card__photo-wrap">
                    <img class="ab-member-card__photo" src="/Lakshmi.jpeg" alt="Lakshmi Narayana Nallamothu" loading="lazy" />
                    <div class="ab-member-card__photo-overlay" aria-hidden="true"></div>
                </div>
                <div class="ab-member-card__body">
                    <span class="ab-member-card__role ab-member-card__role--frontend">Frontend Developer</span>
                    <h3 class="ab-member-card__name">Lakshmi Narayana Nallamothu</h3>
                    <p class="ab-member-card__desc">Built the responsive UI, dark mode theme system, and interaction behavior across all major pages and components.</p>
                </div>
            </article>

            <article class="ab-member-card">
                <div class="ab-member-card__photo-wrap">
                    <img class="ab-member-card__photo" src="/Venky.jpeg" alt="Venkateswararao Jannegorla" loading="lazy" />
                    <div class="ab-member-card__photo-overlay" aria-hidden="true"></div>
                </div>
                <div class="ab-member-card__body">
                    <span class="ab-member-card__role ab-member-card__role--ai">Data &amp; AI Analyst</span>
                    <h3 class="ab-member-card__name">Venkateswararao Jannegorla</h3>
                    <p class="ab-member-card__desc">Defined AI feature flows, risk logic, and model-facing inputs for the lease summarizer and scam detection pipeline.</p>
                </div>
            </article>

            <article class="ab-member-card">
                <div class="ab-member-card__photo-wrap">
                    <img class="ab-member-card__photo" src="/Aravind.PNG" alt="Aravind Polavarapu" loading="lazy" />
                    <div class="ab-member-card__photo-overlay" aria-hidden="true"></div>
                </div>
                <div class="ab-member-card__body">
                    <span class="ab-member-card__role ab-member-card__role--docs">Documentation &amp; QA</span>
                    <h3 class="ab-member-card__name">Aravind Polavarapu</h3>
                    <p class="ab-member-card__desc">Prepared technical documentation, validation notes, and review feedback across all project milestones.</p>
                </div>
            </article>

        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════════
         GITHUB
    ═══════════════════════════════════════════════════════════════ -->
    <a class="ab-github-card reveal"
       href="https://github.com/ln1620/AppDev_Assignment3"
       target="_blank"
       rel="noreferrer noopener"
       aria-label="View TenantLens source code on GitHub">
        <div class="ab-github-card__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="26" height="26">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
        </div>
        <div class="ab-github-card__text">
            <p class="ab-github-card__title">View on GitHub</p>
            <p class="ab-github-card__sub">github.com/ln1620/AppDev_Assignment3</p>
        </div>
        <div class="ab-github-card__arrow" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="18" height="18">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
            </svg>
        </div>
    </a>

</div>

<style>
/* ═══════════════════════════════════════════════════════════
   HERO
═══════════════════════════════════════════════════════════ */
.ab-hero {
    position: relative;
    overflow: hidden;
    padding: 5rem 0 4.5rem;
    background: linear-gradient(
        145deg,
        color-mix(in srgb, var(--accent-indigo) 8%, var(--bg)) 0%,
        color-mix(in srgb, var(--accent-cyan) 6%, var(--bg)) 60%,
        color-mix(in srgb, var(--accent-violet) 5%, var(--bg)) 100%
    );
    border-bottom: 1px solid var(--border);
}

.ab-hero__orbs {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
}

.ab-orb {
    position: absolute;
    border-radius: 999px;
    filter: blur(60px);
    opacity: 0.55;
}

.ab-orb--a {
    width: 420px;
    height: 420px;
    background: var(--orb-1);
    top: -120px;
    right: -80px;
}

.ab-orb--b {
    width: 320px;
    height: 320px;
    background: var(--orb-2);
    bottom: -100px;
    left: -60px;
}

.ab-orb--c {
    width: 200px;
    height: 200px;
    background: var(--orb-3);
    top: 40%;
    left: 55%;
}

.ab-hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25rem;
}

.ab-eyebrow {
    display: inline-block;
    padding: 0.35em 1em;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent-indigo) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent-indigo) 25%, transparent);
    color: var(--accent-indigo);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.03em;
}

.ab-hero__title {
    font-family: "Sora", "Inter", sans-serif;
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    font-weight: 800;
    line-height: 1.1;
    margin: 0;
    background: linear-gradient(135deg, var(--text) 30%, var(--accent-indigo) 70%, var(--accent-cyan) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.ab-hero__sub {
    max-width: 580px;
    margin: 0;
    font-size: 1.05rem;
    color: var(--muted);
    line-height: 1.65;
}

.ab-stats {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0;
    margin-top: 0.5rem;
    border: 1px solid var(--glass-border);
    border-radius: 18px;
    background: color-mix(in srgb, var(--surface-2) 80%, transparent);
    backdrop-filter: blur(10px);
    overflow: hidden;
    box-shadow: var(--glass-shadow);
}

.ab-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1rem 2rem;
    gap: 0.2rem;
    position: relative;
}

.ab-stat + .ab-stat::before {
    content: '';
    position: absolute;
    left: 0;
    top: 20%;
    height: 60%;
    width: 1px;
    background: var(--border);
}

.ab-stat__num {
    font-family: "Sora", "Inter", sans-serif;
    font-size: 1.6rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--accent-indigo), var(--accent-cyan));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
}

.ab-stat__label {
    font-size: 0.75rem;
    color: var(--muted);
    font-weight: 500;
    white-space: nowrap;
}

/* ═══════════════════════════════════════════════════════════
   BODY WRAPPER
═══════════════════════════════════════════════════════════ */
.ab-body {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    padding-top: 2.5rem;
    padding-bottom: 3rem;
}

.ab-section-title {
    font-family: "Sora", "Inter", sans-serif;
    font-size: 1.35rem;
    font-weight: 700;
    margin: 0 0 0.35rem;
}

.ab-section-sub {
    margin: 0 0 1.75rem;
    color: var(--muted);
    font-size: 0.93rem;
}

/* ═══════════════════════════════════════════════════════════
   MISSION
═══════════════════════════════════════════════════════════ */
.ab-mission {
    display: flex;
    gap: 0;
    border-radius: 18px;
    overflow: hidden;
    background: linear-gradient(145deg, var(--surface-2), rgba(255,255,255,0.86));
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow);
}

.ab-mission__accent {
    width: 5px;
    flex-shrink: 0;
    background: linear-gradient(180deg, var(--accent-indigo), var(--accent-cyan));
}

.ab-mission__content {
    padding: 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}

.ab-mission__label {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-indigo);
}

.ab-mission__text {
    margin: 0;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text);
}

/* ═══════════════════════════════════════════════════════════
   WHAT WE BUILT
═══════════════════════════════════════════════════════════ */
.ab-feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
}

.ab-feature-card {
    background: linear-gradient(145deg, var(--surface-2), rgba(255,255,255,0.86));
    border: 1px solid var(--glass-border);
    border-radius: 18px;
    padding: 1.5rem 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    box-shadow: var(--glass-shadow);
    transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
}

.ab-feature-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 36px rgba(27, 75, 110, 0.15);
}

.ab-feature-card__icon {
    width: 46px;
    height: 46px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: #fff;
}

.ab-feature-card__icon--cyan    { background: linear-gradient(135deg, var(--accent-cyan), #38bdf8); }
.ab-feature-card__icon--indigo  { background: linear-gradient(135deg, var(--accent-indigo), var(--accent-violet)); }
.ab-feature-card__icon--violet  { background: linear-gradient(135deg, var(--accent-violet), var(--accent-indigo)); }

.ab-feature-card__title {
    font-family: "Sora", "Inter", sans-serif;
    font-size: 0.97rem;
    font-weight: 700;
    margin: 0;
}

.ab-feature-card__desc {
    margin: 0;
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.6;
}

/* ═══════════════════════════════════════════════════════════
   TEAM
═══════════════════════════════════════════════════════════ */
.ab-team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
}

.ab-member-card {
    background: linear-gradient(145deg, var(--surface-2), rgba(255,255,255,0.9));
    border: 1px solid var(--glass-border);
    border-radius: 22px;
    overflow: hidden;
    box-shadow: var(--glass-shadow);
    transition: transform 0.28s ease, box-shadow 0.28s ease, border-color 0.28s ease;
    display: flex;
    flex-direction: column;
}

.ab-member-card:hover {
    transform: translateY(-8px);
    box-shadow:
        0 24px 48px color-mix(in srgb, var(--accent-indigo) 18%, transparent),
        var(--glass-shadow);
    border-color: color-mix(in srgb, var(--accent-indigo) 35%, var(--glass-border));
}

.ab-member-card__photo-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: var(--surface-2);
}

.ab-member-card__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    transition: transform 0.4s ease;
}

.ab-member-card:hover .ab-member-card__photo {
    transform: scale(1.06);
}

.ab-member-card__photo-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(16, 28, 50, 0.55) 0%, transparent 55%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
}

.ab-member-card:hover .ab-member-card__photo-overlay {
    opacity: 1;
}

.ab-member-card__body {
    padding: 1.25rem 1.3rem 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
}

.ab-member-card__role {
    display: inline-block;
    padding: 0.22em 0.75em;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    align-self: flex-start;
    letter-spacing: 0.01em;
}

.ab-member-card__role--lead     { background: color-mix(in srgb, var(--accent-indigo) 14%, transparent); color: var(--accent-indigo); border: 1px solid color-mix(in srgb, var(--accent-indigo) 28%, transparent); }
.ab-member-card__role--frontend { background: color-mix(in srgb, var(--accent-cyan) 14%, transparent);   color: var(--accent-cyan);   border: 1px solid color-mix(in srgb, var(--accent-cyan) 28%, transparent); }
.ab-member-card__role--ai       { background: color-mix(in srgb, var(--accent-violet) 14%, transparent); color: var(--accent-violet); border: 1px solid color-mix(in srgb, var(--accent-violet) 28%, transparent); }
.ab-member-card__role--docs     { background: color-mix(in srgb, var(--accent-mint) 14%, transparent);   color: var(--accent-mint);   border: 1px solid color-mix(in srgb, var(--accent-mint) 28%, transparent); }

.ab-member-card__name {
    font-family: "Sora", "Inter", sans-serif;
    font-size: 1rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.3;
}

.ab-member-card__desc {
    margin: 0;
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.6;
}

/* ═══════════════════════════════════════════════════════════
   GITHUB CARD
═══════════════════════════════════════════════════════════ */
.ab-github-card {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    padding: 1.25rem 1.5rem;
    border-radius: 18px;
    background: linear-gradient(135deg,
        color-mix(in srgb, var(--surface-2) 95%, var(--accent-indigo)),
        color-mix(in srgb, var(--surface-2) 90%, var(--accent-cyan))
    );
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow);
    text-decoration: none;
    color: var(--text);
    transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
}

.ab-github-card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--accent-indigo) 35%, var(--glass-border));
    box-shadow: 0 16px 32px color-mix(in srgb, var(--accent-indigo) 15%, transparent);
    color: var(--text);
    text-decoration: none;
}

.ab-github-card__icon {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    background: var(--text);
    color: var(--bg);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 0.22s ease;
}

.ab-github-card:hover .ab-github-card__icon {
    transform: rotate(-6deg) scale(1.05);
}

.ab-github-card__text {
    flex: 1;
}

.ab-github-card__title {
    margin: 0;
    font-size: 0.97rem;
    font-weight: 700;
    font-family: "Sora", "Inter", sans-serif;
}

.ab-github-card__sub {
    margin: 0.15rem 0 0;
    font-size: 0.82rem;
    color: var(--muted);
}

.ab-github-card__arrow {
    color: var(--muted);
    transition: transform 0.22s ease, color 0.22s ease;
}

.ab-github-card:hover .ab-github-card__arrow {
    transform: translateX(4px);
    color: var(--accent-indigo);
}

/* ═══════════════════════════════════════════════════════════
   DARK MODE
═══════════════════════════════════════════════════════════ */
html[data-theme="dark"] .ab-hero {
