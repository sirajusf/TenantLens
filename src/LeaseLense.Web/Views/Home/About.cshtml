@{
    ViewData["Title"] = "About";
}

<section class="page-frame reveal">
    <div class="content-hero">
        <h1>About TenantLens</h1>
        <p>
            TenantLens helps renters make high-confidence lease decisions using community-verified reviews,
            scam intelligence, and transparent cost signals before they commit.
        </p>
        <p><a asp-controller="Home" asp-action="Index" class="inline-link">Back to Home</a></p>
    </div>

    <div class="content-grid">
        <article class="content-card">
            <h2>Mission</h2>
            <p>
                Reduce housing risk for students, families, and professionals by making rental experiences
                easier to compare and safer to evaluate.
            </p>
        </article>
        <article class="content-card">
            <h2>What makes it different</h2>
            <p>
                We combine structured tenant input, scam reporting, and AI-assisted insight into one clean
                interface with privacy-first defaults.
            </p>
        </article>
    </div>
</section>
