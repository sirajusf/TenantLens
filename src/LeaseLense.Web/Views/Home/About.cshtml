@{
    ViewData["Title"] = "About";
}

<section class="mvp-shell reveal">

    <div class="page-hero">
        <div class="page-hero__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
        </div>
        <div class="page-hero__text">
            <h1>About Our Team</h1>
            <p>Meet the four contributors behind TenantLens — a rental intelligence platform built for the modern renter.</p>
        </div>
    </div>

    <!-- ── Team grid ── -->
    <div class="mvp-grid about-team-grid">

        <article class="mvp-card about-team-card">
            <div class="about-team-card__avatar">
                <img src="/Siraj2.jpeg" alt="Mahammad Siraj Cheruvu" loading="lazy" />
            </div>
            <div class="about-team-card__body">
                <h2 class="about-team-card__name">Mahammad Siraj Cheruvu</h2>
                <span class="mvp-badge primary about-team-card__role">Project Lead</span>
                <p class="about-team-card__desc">Coordinated planning, product vision, and final integration. Led full-stack architecture and AI feature development.</p>
            </div>
        </article>

        <article class="mvp-card about-team-card">
            <div class="about-team-card__avatar">
                <img src="/Lakshmi.jpeg" alt="Lakshmi Narayana Nallamothu" loading="lazy" />
            </div>
            <div class="about-team-card__body">
                <h2 class="about-team-card__name">Lakshmi Narayana Nallamothu</h2>
                <span class="mvp-badge primary about-team-card__role">Frontend Developer</span>
                <p class="about-team-card__desc">Built the responsive UI, theme system, and interaction behavior across all major pages and components.</p>
            </div>
        </article>

        <article class="mvp-card about-team-card">
            <div class="about-team-card__avatar">
                <img src="/Venky.jpeg" alt="Venkateswararao Jannegorla" loading="lazy" />
            </div>
            <div class="about-team-card__body">
                <h2 class="about-team-card__name">Venkateswararao Jannegorla</h2>
                <span class="mvp-badge primary about-team-card__role">Data &amp; AI Analyst</span>
                <p class="about-team-card__desc">Defined AI feature flows, risk logic, and model-facing inputs including the lease summarizer and scam detection pipeline.</p>
            </div>
        </article>

        <article class="mvp-card about-team-card">
            <div class="about-team-card__avatar">
                <img src="/Aravind.PNG" alt="Aravind Polavarapu" loading="lazy" />
            </div>
            <div class="about-team-card__body">
                <h2 class="about-team-card__name">Aravind Polavarapu</h2>
                <span class="mvp-badge primary about-team-card__role">Documentation &amp; QA</span>
                <p class="about-team-card__desc">Prepared technical documentation, validation notes, and review feedback across all project milestones.</p>
            </div>
        </article>

    </div>

    <!-- ── GitHub ── -->
    <div class="mvp-card about-repo-card reveal">
        <div class="about-repo-card__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
        </div>
        <div class="about-repo-card__text">
            <h2>Source Code</h2>
            <p>The full project is open on GitHub. Browse the code, commit history, and pull requests.</p>
        </div>
        <a class="mvp-btn about-repo-card__link"
           href="https://github.com/ln1620/AppDev_Assignment3"
           target="_blank"
           rel="noreferrer noopener">
            View on GitHub
        </a>
    </div>

</section>

@* ── Page-specific styles ──────────────────────────────────────────────── *@
<style>
.about-team-grid {
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
}

.about-team-card {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 0;
    overflow: hidden;
}

.about-team-card__avatar {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--surface-2);
    flex-shrink: 0;
}

.about-team-card__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    transition: transform 0.35s ease;
}

.about-team-card:hover .about-team-card__avatar img {
    transform: scale(1.04);
}

.about-team-card__body {
    padding: 1.1rem 1.2rem 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
}

.about-team-card__name {
    font-size: 1rem;
    font-weight: 700;
    margin: 0;
    font-family: "Sora", "Inter", sans-serif;
}

.about-team-card__role {
    align-self: flex-start;
}

.about-team-card__desc {
    margin: 0.25rem 0 0;
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.55;
}

/* Repo card */
.about-repo-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
}

.about-repo-card__icon {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: linear-gradient(135deg, var(--surface-2), rgba(255,255,255,0.7));
    border: 1px solid var(--glass-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--fg);
}

.about-repo-card__text {
    flex: 1;
    min-width: 160px;
}

.about-repo-card__text h2 {
    margin: 0 0 0.2rem;
    font-size: 1rem;
    font-weight: 700;
}

.about-repo-card__text p {
    margin: 0;
    font-size: 0.875rem;
    color: var(--muted);
}

.about-repo-card__link {
    flex-shrink: 0;
}

html[data-theme="dark"] .about-repo-card__icon {
    background: rgba(22, 33, 52, 0.75);
    border-color: rgba(165, 192, 224, 0.18);
}
</style>
