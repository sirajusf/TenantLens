@model LeaseLense.Web.Models.Home.HomeIndexViewModel
@{
    ViewData["Title"] = "Home";
}
<section class="hero">
        <div class="container hero-grid">
          <div class="hero-main reveal">
            <div class="hero-orbs" aria-hidden="true">
              <span class="orb orb-a"></span>
              <span class="orb orb-b"></span>
              <span class="orb orb-c"></span>
            </div>
            <p class="eyebrow">Smart Rental Decisions</p>
            <h1>Know Before You Rent</h1>
            <p class="hero-text">
              A tenant-first, AI-powered platform designed to help renters
              uncover the real story behind a property before signing a lease.
            </p>
            <p class="hero-purpose">
              Our purpose is to reduce rental fraud, hidden costs, and bad lease
              decisions by combining community data, fraud reporting, cost
              transparency, and AI-powered lease/risk assistance to help people
              make safer housing decisions.
            </p>
            <div class="hero-trust">
              <article>
                <p class="trust-value">32K+</p>
                <p class="trust-label">community signals</p>
              </article>
              <article>
                <p class="trust-value">18s</p>
                <p class="trust-label">avg insight response</p>
              </article>
              <article>
                <p class="trust-value">91%</p>
                <p class="trust-label">decision confidence boost</p>
              </article>
            </div>
            <div class="search-shell glow-border">
              <p class="search-label">Start with Search</p>
              <div class="search-tabs" aria-hidden="true">
                <span class="tab active">Properties</span>
                <span class="tab">Scam Reports</span>
                <span class="tab">Lease Risk</span>
                <span class="tab">Renter Fit</span>
              </div>
              <form class="search-bar" role="search" method="get" asp-controller="Properties" asp-action="Index">
              <label class="sr-only" for="property-search"
                >Search properties by name or address</label
              >
              <input
                id="property-search"
                type="search"
                name="q"
                placeholder="Search properties by name or address..."
              />
              <button type="submit">Search Properties</button>
              </form>
              <div class="quick-chips">
                <span>Building</span>
                <span>Address</span>
                <span>Landlord</span>
                <span>Management Company</span>
              </div>
              <p id="search-feedback" class="search-feedback" aria-live="polite"></p>
            </div>
          </div>
          <aside class="hero-panel reveal">
            <h2>Why this matters</h2>
            <p class="panel-note">Renting should feel safer, not riskier.</p>
            <ul class="matter-list">
              <li>Confidence before lease signing</li>
              <li>Transparent costs before move-in</li>
              <li>Fraud signals before deposit payment</li>
            </ul>
            <div class="matter-stats">
              <article>
                <p class="stat-value">12K+</p>
                <p class="stat-label">searches/month</p>
              </article>
              <article>
                <p class="stat-value">87%</p>
                <p class="stat-label">users avoid hidden fees</p>
              </article>
              <article>
                <p class="stat-value">4.8/5</p>
                <p class="stat-label">tenant trust score</p>
              </article>
            </div>
          </aside>
        </div>
      </section>

<section id="features" class="features container reveal">
        <h2>Key MVP Features</h2>
        <div class="feature-grid">
          <article class="feature-card accent-cyan">
            <h3>Building & Landlord Reputation</h3>
            <p>
              Snapshot scores and recurring issue alerts for properties and
              landlords.
            </p>
          </article>
          <article class="feature-card accent-indigo">
            <h3>Structured Anonymous Reviews</h3>
            <p>
              Consistent, privacy-safe tenant feedback across maintenance,
              costs, and communication.
            </p>
          </article>
          <article class="feature-card accent-violet">
            <h3>AI Lease Red Flag Scanner</h3>
            <p>
              Detect risky clauses and highlight sections that need clarification
              before signing.
            </p>
          </article>
          <article class="feature-card accent-coral">
            <h3>Scam & Fraud Reporting</h3>
            <p>
              Separate fraud reports to flag fake listings, deposit scams, and
              suspicious activity.
            </p>
          </article>
          <article class="feature-card accent-mint">
            <h3>True Cost & Hidden Fee Estimator</h3>
            <p>
              Estimate actual monthly and move-in costs beyond advertised base
              rent.
            </p>
          </article>
        </div>
      </section>

<section id="ai-assistants" class="ai-assistants container reveal">
        <div class="section-head">
          <h2>AI Assistants</h2>
          <p>New intelligence modules for smarter renter decisions</p>
        </div>
        <div class="assistant-grid">
          <article class="assistant-card accent-indigo">
            <h3>Natural Language Search</h3>
            <p>
              Search the platform using plain language like "2-bed under $1800
              with low scam risk and fast maintenance."
            </p>
          </article>
          <article class="assistant-card accent-cyan">
            <h3>Renter Fit Assistant</h3>
            <p>
              Get personalized property matches based on budget, commute,
              lifestyle preferences, and risk tolerance.
            </p>
          </article>
          <article class="assistant-card accent-violet">
            <h3>Negotiation Copilot</h3>
            <p>
              Generate negotiation points and landlord questions from lease red
              flags and listing signals.
            </p>
          </article>
          <article class="assistant-card accent-mint">
            <h3>Deposit Recovery Assistant</h3>
            <p>
              Build a post move-out recovery plan with dispute checklists,
              evidence guidance, and draft-ready request language.
            </p>
          </article>
        </div>
      </section>

<section class="reviews container reveal">
        <div class="section-head">
          <h2>Recent Rental Reviews</h2>
          <a class="section-link" asp-controller="Reviews" asp-action="Index">More reviews</a>
        </div>
        <div class="review-grid">
          @foreach (var review in Model.Reviews)
          {
            <article class="review-card">
              <div class="review-top">
                <h3>@review.PropertyTitle</h3>
                <p class="rating">@((review.AverageRating ?? 0).ToString("0.0"))/5</p>
              </div>
              <p class="location">@review.City</p>
              <p class="review-quote">@review.ReviewText</p>
              <div class="tags">
                @if (!string.IsNullOrWhiteSpace(review.VerificationBadge))
                {
                  <span>@review.VerificationBadge</span>
                }
                <span>@((review.MonthlyRent ?? 0).ToString("C0"))/mo</span>
                <span>Community Signal</span>
              </div>
            </article>
          }
        </div>
      </section>

<section class="fraud-reports container reveal">
        <div class="section-head">
          <h2>Recent Fraud Alerts</h2>
          <a class="section-link" asp-controller="ScamReports" asp-action="Index">More reports</a>
        </div>
        <div class="fraud-grid">
          @foreach (var report in Model.ScamReports)
          {
            <article class="fraud-card">
              <div class="fraud-top">
                <h3>@report.PropertyTitle</h3>
                <span class="severity @((report.SeverityScore ?? 0) >= 3 ? "high" : "medium")">
                  Severity @((report.SeverityScore ?? 0).ToString("0.0"))
                </span>
              </div>
              <p class="location">@report.City · @report.ScamType</p>
              <p class="fraud-quote">@report.Description</p>
              @if (!string.IsNullOrWhiteSpace(report.VerificationBadge))
              {
                <div class="tags">
                  <span>@report.VerificationBadge</span>
                </div>
              }
            </article>
          }
        </div>
      </section>

<section class="story-visuals container reveal">
        <div class="section-head">
          <h2>TenantLens in Action</h2>
          <p>Visual snapshots of how renters use intelligence before signing</p>
        </div>
        <div class="visual-grid">
          <figure class="visual-card accent-cyan">
            <img
              src="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&w=1400&q=80"
              alt="Renter reviewing lease terms and housing insights on a laptop"
              loading="lazy"
            />
            <figcaption>Lease and risk checks before commitment.</figcaption>
          </figure>
          <figure class="visual-card accent-indigo">
            <img
              src="https://images.unsplash.com/photo-1556740758-90de374c12ad?auto=format&fit=crop&w=1400&q=80"
              alt="Tenant comparing rental fees and cost breakdown data"
              loading="lazy"
            />
            <figcaption>Transparent move-in and monthly cost visibility.</figcaption>
          </figure>
          <figure class="visual-card accent-mint">
            <img
              src="https://images.unsplash.com/photo-1521790797524-b2497295b8a0?auto=format&fit=crop&w=1400&q=80"
              alt="Two renters discussing safer housing choices based on reports"
              loading="lazy"
            />
            <figcaption>Community-powered fraud awareness and safer decisions.</figcaption>
          </figure>
        </div>
      </section>

<section id="testimonials" class="testimonials container reveal">
        <div class="section-head">
          <h2>Recently Added Properties</h2>
          <p>Properties sourced from the current `properties` table</p>
        </div>
        <div class="testimonial-grid">
          @foreach (var property in Model.Properties)
          {
            <a class="testimonial-card" asp-controller="Properties" asp-action="Details" asp-route-id="@property.PropertyId">
              <div class="avatar">@((string.IsNullOrWhiteSpace(property.Title) ? "P" : property.Title[..1]).ToUpperInvariant())</div>
              <div>
                <h3>@property.Title</h3>
                <p class="role">@property.StreetAddress</p>
                <p>@property.City, @property.Country</p>
              </div>
            </a>
          }
        </div>
      </section>
