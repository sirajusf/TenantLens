@{
    ViewData["Title"] = "Lease Summarizer";
}

<section class="mvp-shell reveal">
    <div class="mvp-hero">
        <h1>Lease Summarizer</h1>
        <p>Upload a lease document and get a structured summary of rent, fees, term length, and critical clauses.</p>
    </div>

    @if (TempData["LeaseSummarizerError"] is string error)
    {
        <div class="mvp-error">@error</div>
    }

    <article class="mvp-card accent-indigo">
        <h2>Upload lease document</h2>
        <p class="mvp-text">Accepted files: PDF, PNG, or JPEG (max 10 MB).</p>

        <form asp-action="Submit" method="post" enctype="multipart/form-data" class="mvp-form">
            @Html.AntiForgeryToken()
            <div class="mvp-form-grid">
                <div class="mvp-field full">
                    <label class="mvp-label" for="leaseDocument">Lease file</label>
                    <input id="leaseDocument" name="leaseDocument" type="file" class="mvp-input" accept=".pdf,.png,.jpg,.jpeg" required />
                </div>
            </div>
            <div class="mvp-actions">
                <button type="submit" class="mvp-btn">Summarize lease</button>
            </div>
        </form>
    </article>
</section>

