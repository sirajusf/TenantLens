@{
    ViewData["Title"] = "Lease Summary";
    var jobId = ViewData["LeaseSummarizerJobId"]?.ToString() ?? string.Empty;
}

<div class="ls-page">
    <div class="container">

        <header class="ls-header reveal">
            <div class="ls-header__icon ls-header__icon--processing" id="ls-header-icon" aria-hidden="true">
                <svg id="ls-icon-processing" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/>
                    <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
                </svg>
                <svg id="ls-icon-done" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" hidden>
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <polyline points="9 15 11 17 15 13"/>
                </svg>
            </div>
            <div class="ls-header__text">
                <h1 id="ls-page-title">Analyzing your lease&hellip;</h1>
                <p id="ls-page-sub">This usually takes 10–30 seconds. You can stay on this page — it updates automatically.</p>
            </div>
        </header>

        <div class="ls-progress reveal" id="ls-progress" aria-label="Analysis progress">
            <div class="ls-progress__step ls-progress__step--done" id="ls-step-queued">
                <span class="ls-progress__dot"></span>
                <span class="ls-progress__label">Queued</span>
            </div>
            <div class="ls-progress__line"></div>
            <div class="ls-progress__step" id="ls-step-processing">
                <span class="ls-progress__dot"></span>
                <span class="ls-progress__label">Processing</span>
            </div>
            <div class="ls-progress__line"></div>
            <div class="ls-progress__step" id="ls-step-done">
                <span class="ls-progress__dot"></span>
                <span class="ls-progress__label">Complete</span>
            </div>
        </div>

        <div class="ls-risk-banner" id="ls-risk-banner" hidden>
            <div class="ls-risk-banner__score" id="ls-risk-score-block"></div>
            <div class="ls-risk-banner__meta" id="ls-risk-meta"></div>
            <div class="ls-risk-banner__confidence" id="ls-risk-confidence"></div>
        </div>

        <div id="ls-summary-root" hidden>

            <div class="ls-sections-grid" id="ls-sections-grid"></div>

            <div class="ls-clauses-section" id="ls-clauses-section" hidden>
                <h2 class="ls-section-title">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="18" height="18" aria-hidden="true"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
                    Flagged Clauses
                </h2>
                <p class="ls-clauses-note">These clauses were identified as potentially risky. Read them carefully before signing.</p>
                <div class="ls-clauses-grid" id="ls-clauses-grid"></div>
            </div>

            <div class="ls-narrative-section" id="ls-narrative-section" hidden>
                <h2 class="ls-section-title">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="18" height="18" aria-hidden="true"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd"/></svg>
                    Full AI Narrative
                </h2>
                <div class="ls-narrative" id="ls-narrative"></div>
            </div>

            <div class="ls-actions-bar">
                <a href="/LeaseSummarizer" class="ls-action-btn ls-action-btn--ghost">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16" aria-hidden="true"><path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd"/></svg>
                    Analyze another lease
                </a>
            </div>
        </div>

        <div id="ls-error-root" hidden>
            <div class="ls-alert ls-alert--error ls-alert--block" role="alert">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="20" height="20" aria-hidden="true"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
                <div>
                    <strong>Analysis failed</strong>
                    <p id="ls-error-msg" class="ls-alert__detail"></p>
                </div>
            </div>
            <div class="ls-actions-bar">
                <a href="/LeaseSummarizer" class="ls-action-btn ls-action-btn--primary">Try again</a>
            </div>
        </div>

    </div>
</div>

@section Scripts {
<script>
(function () {
    var JOB_ID = "@jobId";
    if (!JOB_ID) return;

    // ── DOM references
    var stepQueued     = document.getElementById("ls-step-queued");
    var stepProcessing = document.getElementById("ls-step-processing");
    var stepDone       = document.getElementById("ls-step-done");
    var pageTitle      = document.getElementById("ls-page-title");
    var pageSub        = document.getElementById("ls-page-sub");
    var riskBanner     = document.getElementById("ls-risk-banner");
    var riskScoreBlock = document.getElementById("ls-risk-score-block");
    var riskMeta       = document.getElementById("ls-risk-meta");
    var riskConf       = document.getElementById("ls-risk-confidence");
    var summaryRoot    = document.getElementById("ls-summary-root");
    var sectionsGrid   = document.getElementById("ls-sections-grid");
    var clausesSection = document.getElementById("ls-clauses-section");
    var clausesGrid    = document.getElementById("ls-clauses-grid");
    var narrativeSection = document.getElementById("ls-narrative-section");
    var narrativeEl    = document.getElementById("ls-narrative");
    var errorRoot      = document.getElementById("ls-error-root");
    var errorMsg       = document.getElementById("ls-error-msg");
    var iconProc       = document.getElementById("ls-icon-processing");
    var iconDone       = document.getElementById("ls-icon-done");
    var headerIcon     = document.getElementById("ls-header-icon");

    // ── Helpers
    function esc(s) {
        if (s == null) return "";
        var d = document.createElement("div");
        d.textContent = String(s);
        return d.innerHTML;
    }

    function money(n, cur) {
        if (n == null || isNaN(Number(n))) return null;
        try { return new Intl.NumberFormat(undefined, { style: "currency", currency: (cur || "USD").toUpperCase() }).format(Number(n)); }
        catch (e) { return String(n); }
    }

    function riskClass(level) {
        if (!level) return "";
        var l = level.toLowerCase();
        if (l === "high") return "ls-risk--high";
        if (l === "medium" || l === "moderate") return "ls-risk--medium";
        return "ls-risk--low";
    }

    function riskLabel(level) {
        if (!level) return "Unknown";
        var l = level.toLowerCase();
        if (l === "high") return "⚠ High Risk";
        if (l === "medium" || l === "moderate") return "◈ Medium Risk";
        return "✓ Low Risk";
    }

    function scoreClass(score) {
        if (score == null) return "";
        var n = Number(score);
        if (n >= 3.5) return "ls-score--high";
        if (n >= 2) return "ls-score--medium";
        return "ls-score--low";
    }

    // ── Build a section card
    function card(title, icon, bodyHtml) {
        if (!bodyHtml || !bodyHtml.trim()) return "";
        return '<div class="ls-section-card">' +
               '<div class="ls-section-card__head"><span class="ls-section-card__icon" aria-hidden="true">' + icon + '</span><h3>' + esc(title) + '</h3></div>' +
               '<div class="ls-section-card__body">' + bodyHtml + '</div>' +
               '</div>';
    }

    // ── Build a definition list
    function dl(rows) {
        var filtered = rows.filter(function(r){ return r.v != null && String(r.v).trim() !== ""; });
        if (!filtered.length) return "";
        var h = '<dl class="ls-dl">';
        filtered.forEach(function(r) { h += '<div class="ls-dl__row"><dt>' + esc(r.k) + '</dt><dd>' + esc(String(r.v)) + '</dd></div>'; });
        h += '</dl>';
        return h;
    }

    // ── Build a list
    function ul(items) {
        var filtered = items.filter(function(i){ return i != null && String(i).trim() !== ""; });
        if (!filtered.length) return "";
        return '<ul class="ls-list">' + filtered.map(function(i){ return '<li>' + esc(String(i)) + '</li>'; }).join("") + '</ul>';
    }

    // ── Render the full structured summary
    function renderSummary(data) {
        var obj = null;
        if (data.structuredSummaryJson) {
            try { obj = JSON.parse(data.structuredSummaryJson); } catch(e){}
        }

        // Risk banner
        riskBanner.hidden = false;
        var riskLevel = (obj && obj.riskLevel) || data.riskLevel || "";
        var riskScore = (obj && obj.summaryRiskScore) || data.summaryRiskScore;
        var conf      = (obj && obj.confidence)      || data.confidence;

        riskScoreBlock.innerHTML =
            '<span class="ls-risk-badge ' + riskClass(riskLevel) + '">' + riskLabel(riskLevel) + '</span>' +
            (riskScore != null ? '<span class="ls-score ' + scoreClass(riskScore) + '">' + Number(riskScore).toFixed(1) + '<span class="ls-score__max">/5</span></span>' : '');

        riskMeta.innerHTML = '<p class="ls-risk-banner__label">Overall Risk Score</p>';

        if (conf != null) {
            riskConf.innerHTML = '<span class="ls-conf-badge">AI confidence: ' + Math.round(Number(conf) * 100) + '%</span>';
        }

        if (!obj) {
            // Fallback: plain narrative only
            var nar = document.createElement("div");
            nar.className = "ls-narrative";
            nar.textContent = data.summaryText || "No structured data available.";
            sectionsGrid.appendChild(nar);
            summaryRoot.hidden = false;
            return;
        }

        var sections = "";
        var cur = (obj.money && obj.money.currency) || "USD";

        // Property address
        var addr = "";
        if (obj.premises && typeof obj.premises === "object") {
            var p = obj.premises;
            addr = [p.fullAddress || [p.street, p.unit, p.city, p.state, p.postalCode, p.country].filter(Boolean).join(", ")].filter(Boolean).join("");
        }
        sections += card("Property Address",
            '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>',
            addr ? '<p class="ls-address">' + esc(addr) + '</p>' : "");

        // Parties
        var parties = obj.parties && typeof obj.parties === "object" ? obj.parties : null;
        if (parties) {
            var prows = [];
            var landlord = parties.landlordOrLeaseOwnerName || parties.landlordName || parties.leaseOwnerName;
            if (landlord) prows.push({ k: "Landlord / Lease Owner", v: landlord });
            if (parties.propertyManagerOrAgent) prows.push({ k: "Property Manager / Agent", v: parties.propertyManagerOrAgent });
            var tenants = Array.isArray(parties.tenantNames) ? parties.tenantNames.filter(Boolean) : [];
            if (tenants.length) prows.push({ k: "Tenant(s)", v: tenants.join(", ") });
            sections += card("Parties",
                '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"/></svg>',
                dl(prows));
        }

        // Lease term
        var term = obj.term && typeof obj.term === "object" ? obj.term : null;
        if (term) {
            var trows = [];
            if (term.startDate) trows.push({ k: "Start Date", v: term.startDate });
            if (term.endDate)   trows.push({ k: "End Date",   v: term.endDate });
            if (term.months != null) trows.push({ k: "Term Length", v: term.months + " months" });
            if (term.renewalType)    trows.push({ k: "Renewal", v: term.renewalType });
            if (term.earlyTermination) trows.push({ k: "Early Termination", v: term.earlyTermination });
            sections += card("Lease Term",
                '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/></svg>',
                dl(trows));
        }

        // Money
        var m = obj.money && typeof obj.money === "object" ? obj.money : null;
        if (m) {
            var mrows = [];
            var mr = m.monthlyRent;
            if (mr && typeof mr === "object") {
                var amt = money(mr.amount, cur);
                if (amt) mrows.push({ k: "Monthly Rent", v: amt });
                if (mr.dueDayOfMonth != null) mrows.push({ k: "Due Day of Month", v: String(mr.dueDayOfMonth) });
                if (mr.gracePeriodDays != null) mrows.push({ k: "Grace Period", v: mr.gracePeriodDays + " days" });
            }
            var sd = m.securityDeposit;
            if (sd && typeof sd === "object") {
                var sa = money(sd.amount, cur);
                if (sa) mrows.push({ k: "Security Deposit", v: sa + (sd.dueWhen ? " — " + sd.dueWhen : "") });
            }
            if (Array.isArray(m.otherDeposits)) {
                m.otherDeposits.forEach(function(d) {
                    if (!d) return;
                    var da = money(d.amount, cur);
                    mrows.push({ k: (d.type || "Other Deposit"), v: (da || "") + (d.dueWhen ? " — " + d.dueWhen : "") });
                });
            }
            var lf = m.lateFees;
            if (lf && typeof lf === "object") {
                var bits = [];
                if (lf.amount != null) bits.push(money(lf.amount, cur) || String(lf.amount));
                if (lf.perDayAmount != null) bits.push("+" + (money(lf.perDayAmount, cur) || lf.perDayAmount) + "/day");
                if (lf.percent != null) bits.push(lf.percent + "%");
                if (lf.notes) bits.push(lf.notes);
                if (bits.length) mrows.push({ k: "Late Fees", v: bits.join("; ") });
            }
            var nsf = m.nsfFees;
            if (nsf && (nsf.amount != null || nsf.notes)) {
                mrows.push({ k: "NSF / Returned Payment", v: (money(nsf.amount, cur) || "") + (nsf.notes ? " — " + nsf.notes : "") });
            }
            if (Array.isArray(m.recurringCharges)) {
                m.recurringCharges.forEach(function(c) {
                    if (!c) return;
                    var ca = money(c.amount, cur);
                    mrows.push({ k: "Recurring: " + (c.type || "Charge"), v: [ca, c.frequency, c.notes].filter(Boolean).join(" — ") });
                });
            }
            if (Array.isArray(m.oneTimeFees)) {
                m.oneTimeFees.forEach(function(c) {
                    if (!c) return;
                    var ca = money(c.amount, cur);
                    mrows.push({ k: "One-time: " + (c.type || "Fee"), v: [ca, c.when, c.notes].filter(Boolean).join(" — ") });
                });
            }
            sections += card("Rent & Financials",
                '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"/><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd"/></svg>',
                dl(mrows));

            // Utilities
            var utils = m.utilities;
            if (Array.isArray(utils) && utils.length) {
                var utilRows = utils.filter(function(u){ return u && typeof u === "object"; }).map(function(u) {
                    return { k: u.utility || "Utility", v: (u.paidBy || "") + (u.notes ? " — " + u.notes : "") };
                });
                sections += card("Utilities",
                    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"/></svg>',
                    dl(utilRows));
            }
        }

        // Notices
        var notices = obj.notices && typeof obj.notices === "object" ? obj.notices : null;
        if (notices) {
            var nrows = [];
            if (notices.moveOutNoticeDays != null)      nrows.push({ k: "Move-out Notice", v: notices.moveOutNoticeDays + " days" });
            if (notices.terminationNoticeDays != null)  nrows.push({ k: "Termination Notice", v: notices.terminationNoticeDays + " days" });
            if (notices.entryNoticeHours != null)       nrows.push({ k: "Landlord Entry Notice", v: notices.entryNoticeHours + " hours" });
            if (notices.rentIncreaseNoticeDays != null) nrows.push({ k: "Rent Increase Notice", v: notices.rentIncreaseNoticeDays + " days" });
            if (Array.isArray(notices.other) && notices.other.length) nrows.push({ k: "Other", v: notices.other.join("; ") });
            sections += card("Notice Requirements",
                '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zM10 18a3 3 0 01-3-3h6a3 3 0 01-3 3z"/></svg>',
                dl(nrows));
        }

        // Move-out
        var mo = obj.moveOut && typeof obj.moveOut === "object" ? obj.moveOut : null;
        if (mo) {
            var morows = [];
            if (mo.cleaningRequirements) morows.push({ k: "Cleaning", v: mo.cleaningRequirements });
            if (mo.repairDeductions)     morows.push({ k: "Repairs / Deductions", v: mo.repairDeductions });
            if (Array.isArray(mo.professionalServicesRequired) && mo.professionalServicesRequired.length)
                morows.push({ k: "Professional Services Required", v: mo.professionalServicesRequired.join(", ") });
            sections += card("Move-out Requirements",
                '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path d="M3 1a1 1 0 000 2h1.22l.305 1.222a.997.997 0 00.01.042l1.358 5.43-.893.892C3.74 11.846 4.632 14 6.414 14H15a1 1 0 000-2H6.414l1-1H14a1 1 0 00.894-.553l3-6A1 1 0 0017 3H6.28l-.31-1.243A1 1 0 005 1H3z"/><path d="M16 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM6.5 18a1.5 1.5 0 100-3 1.5 1.5 0 000 3z"/></svg>',
                dl(morows));
        }

        // Highlights
        if (Array.isArray(obj.highlights) && obj.highlights.length) {
            sections += card("Key Highlights",
                '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>',
                ul(obj.highlights));
        }

        sectionsGrid.innerHTML = sections;
        summaryRoot.hidden = false;

        // Clause flags
        var flags = data.clauseFlags;
        if (Array.isArray(flags) && flags.length) {
            clausesSection.hidden = false;
            var flagsHtml = "";
            flags.forEach(function(f) {
                if (!f) return;
                var rl = (f.riskLevel || "").toLowerCase();
                var rc = rl === "high" ? "ls-clause--high" : (rl === "medium" || rl === "moderate") ? "ls-clause--medium" : "ls-clause--low";
                flagsHtml += '<article class="ls-clause ' + rc + '">' +
                    '<div class="ls-clause__head">' +
                    '<span class="ls-clause__type">' + esc(f.clauseType || "Clause") + '</span>' +
                    '<span class="ls-clause__risk">' + riskLabel(f.riskLevel) + '</span>' +
                    '</div>' +
                    (f.flaggedText ? '<blockquote class="ls-clause__quote">' + esc(f.flaggedText) + '</blockquote>' : '') +
                    (f.explanation ? '<p class="ls-clause__explanation">' + esc(f.explanation) + '</p>' : '') +
                    (f.suggestedQuestion ? '<p class="ls-clause__question"><strong>Ask:</strong> ' + esc(f.suggestedQuestion) + '</p>' : '') +
                    '</article>';
            });
            clausesGrid.innerHTML = flagsHtml;
        }

        // Full narrative
        var narrative = data.summaryText || (obj && obj.summaryText);
        if (narrative && String(narrative).trim()) {
            narrativeSection.hidden = false;
            narrativeEl.innerHTML = '<p>' + esc(String(narrative)) + '</p>';
        }
    }

    // ── Progress states
    function setStep(status) {
        ["done"].forEach(function(c) {
            stepQueued.classList.remove("ls-progress__step--done", "ls-progress__step--active");
            stepProcessing.classList.remove("ls-progress__step--done", "ls-progress__step--active");
            stepDone.classList.remove("ls-progress__step--done", "ls-progress__step--active");
        });
        if (status === "queued") {
            stepQueued.classList.add("ls-progress__step--active");
        } else if (status === "processing") {
            stepQueued.classList.add("ls-progress__step--done");
            stepProcessing.classList.add("ls-progress__step--active");
        } else if (status === "succeeded") {
            stepQueued.classList.add("ls-progress__step--done");
            stepProcessing.classList.add("ls-progress__step--done");
            stepDone.classList.add("ls-progress__step--done");
        } else if (status === "failed") {
            stepQueued.classList.add("ls-progress__step--done");
            stepProcessing.classList.add("ls-progress__step--done");
        }
    }

    // ── Poll
    var POLL_MS = 2000;
    var done = false;

    function poll() {
        if (done) return;
        fetch("/LeaseSummarizer/StatusJson?id=" + encodeURIComponent(JOB_ID), { headers: { "Accept": "application/json" } })
            .then(function(r) { return r.ok ? r.json() : null; })
            .then(function(data) {
                if (!data) { setTimeout(poll, POLL_MS); return; }
                var status = (data.status || "").toLowerCase();
                setStep(status);

                if (status === "succeeded") {
                    done = true;
                    pageTitle.textContent = "Lease Summary Ready";
                    pageSub.textContent = "Review the structured breakdown below. Flagged clauses deserve a second look.";
                    iconProc.hidden = true;
                    iconDone.hidden = false;
                    headerIcon.classList.remove("ls-header__icon--processing");
                    headerIcon.classList.add("ls-header__icon--done");
                    renderSummary(data);
                } else if (status === "failed") {
                    done = true;
                    pageTitle.textContent = "Analysis Failed";
                    pageSub.textContent = "Something went wrong processing your document.";
                    errorMsg.textContent = data.errorMessage || "An unexpected error occurred. Please try again.";
                    errorRoot.hidden = false;
                } else {
                    if (status === "processing") { pageSub.textContent = "AI is reading your lease…"; }
                    setTimeout(poll, POLL_MS);
                }
            })
            .catch(function() { setTimeout(poll, POLL_MS); });
    }

    setStep("queued");
    poll();
})();
</script>
}
