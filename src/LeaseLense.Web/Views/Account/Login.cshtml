@model LeaseLense.Web.Models.Account.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
}

<section class="mvp-shell reveal">
    <div class="mvp-hero">
        <h1>Welcome Back</h1>
        <p>Sign in to submit reviews and scam reports with your account.</p>
    </div>

    <form asp-action="Login" method="post" class="mvp-form">
        <input asp-for="ReturnUrl" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="mvp-error"></div>
        <div class="mvp-form-grid">
            <div class="mvp-field full">
                <label asp-for="Email" class="mvp-label">Email</label>
                <input asp-for="Email" class="mvp-input" />
                <span asp-validation-for="Email" class="mvp-error"></span>
            </div>
            <div class="mvp-field full">
                <label asp-for="Password" class="mvp-label">Password</label>
                <input asp-for="Password" class="mvp-input" />
                <span asp-validation-for="Password" class="mvp-error"></span>
            </div>
        </div>
        <div class="mvp-actions">
            <button type="submit" class="mvp-btn">Sign In</button>
            <a class="mvp-btn ghost" asp-action="Register">Create Account</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
